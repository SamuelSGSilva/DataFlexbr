# Copie este arquivo para .env.local e preencha. Peça os valores reais ao Samuel.
# Supabase: painel > Settings > API Keys (Publishable key) e Settings > Data API (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SUA-CHAVE-AQUI

# Segredo que assina o passe de acesso dos cadastrados (qualquer texto longo e aleatório).
# Gere um novo com: node -e "console.log(crypto.randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=troque-por-um-texto-aleatorio-bem-longo

# Login único e compartilhado da área /datacenter
DATACENTER_USER=troque-o-usuario
DATACENTER_PASSWORD=troque-a-senha

# Evolution API (envio do código de confirmação por WhatsApp no cadastro novo)
EVOLUTION_API_URL=https://evolution.autoluiz.net
EVOLUTION_API_KEY=troque-pela-apikey-da-instancia
EVOLUTION_INSTANCE=nome-da-instancia

# --- Só para rodar via Docker (docker-compose.yml), banco self-hosted ---
# Copie este arquivo para ".env" (sem ".example") na raiz do projeto.
POSTGRES_PASSWORD=troque-por-uma-senha-forte
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-jwt-de-32-caracteres-ou-mais
# SUPABASE_ANON_KEY e SUPABASE_SERVICE_KEY são JWTs assinados com o
# JWT_SECRET acima (role "anon" e "service_role"). Peça ao Claude para
# gerar um novo par sempre que trocar o JWT_SECRET.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=


# Marque como true SOMENTE quando o site estiver atras de HTTPS.
# Em HTTP puro (acesso por IP:porta) deixe false/vazio, senao o cookie
# de login e descartado pelo navegador e a sessao nao persiste.
COOKIE_SECURE=false
