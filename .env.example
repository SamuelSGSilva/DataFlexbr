# Copie este arquivo para .env.local e preencha. Peça os valores reais ao Samuel.
# Supabase: painel > Settings > API Keys (Publishable key) e Settings > Data API (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_SUA-CHAVE-AQUI

# Segredo que assina o passe de acesso dos cadastrados (qualquer texto longo e aleatório).
# Gere um novo com: node -e "console.log(crypto.randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=troque-por-um-texto-aleatorio-bem-longo

# Login único e compartilhado da área /datacenter
DATACENTER_USER=troque-o-usuario
DATACENTER_PASSWORD=troque-a-senha

# Brevo (envio do código de confirmação por email no login de "já tenho cadastro")
# API key: painel Brevo > Settings > SMTP & API > API Keys
BREVO_API_KEY=xkeysib-sua-chave-aqui
BREVO_SENDER_EMAIL=remetente-verificado@seu-dominio.com
